[discord]
token = <discord_token>

[sso]
encryption_key = <encryption_key>
ssl_certfile = <path_to_cert_file>
ssl_keyfile = <path_to_key_file>
host = 0.0.0.0
port = 443
# Rate limiting: block an IP after this many failed auth attempts within the window
#rate_limit_max_attempts = 20
#rate_limit_window_minutes = 30

[raidtargets]
endpoint = http://path/to/raidtarget.json

[ds]
points_per_minute = 3
contested_multiplier = 3
quake_bonus = 150

[wakeup]
audiofile = wakeup.wav

[guild.12345]
# Member Role is necessary for raidtarget commands to work
member_role = 77777

# Raidtarget, batphone, DS, and SSO commands default to false, but can be enabled:
enable_raidtarget = true
enable_batphone = true
enable_ds = true
ds_tod_channel = <channel_id>
ds_schedule_channel = <channel_id>
ds_admin_role = <role_id>
enable_sso = true
sso_admin_roles = <role_id1>, <role_id2>

# Timer and Random functions default to true, but can be disabled:
enable_timer = false
enable_random = false

# Wakeup channel mappings
wakeup_channels = textchannel_id1:voicechannel_id1, textchannel_id2:voicechannel_id2

# Minimum SSO client version required to connect (optional, omit to allow any version)
# Clients below this version are rejected with client_update_message shown as a popup
#min_client_version = 1.2.0
#client_update_message = Your SSO client is outdated. Please download the latest version.

# Require EQ logging to be enabled (Log=TRUE in eqclient.ini).
# Older clients that don't send client_settings are allowed through regardless.
# Pair with min_client_version to enforce this for all users.
#require_log = true

# Block clients that have the Rustle UI skin in their uifiles directory.
# Older clients that don't send client_settings are allowed through regardless.
# Pair with min_client_version to enforce this for all users.
#block_rustle = true
# Discord roles exempt from the Rustle block (comma-separated role IDs)
#block_rustle_exempt_roles = 123456789, 987654321

[guild.67890]
# Raid Subscription commands will be unusable.
enable_raidtarget = false
